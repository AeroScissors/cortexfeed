# Copy this file to .env and adjust values as needed
# cp .env.example .env

# Ollama server URL (default: local)
OLLAMA_URL=http://localhost:11434

# Default model to use — run `ollama list` to see what you have installed
# Popular options: mistral, llama3, codellama, phi3, gemma
DEFAULT_MODEL=mistral:latest

# How often (in seconds) the file watcher checks for changes
WATCH_INTERVAL=2

# Max file size to read (in KB) — files larger than this are skipped
MAX_FILE_KB=200
