# Copy this file to .env and adjust values as needed
# cp .env.example .env

# ── AI Backend ───────────────────────────────────────────────
# Choose one: ollama (default, free, local) | openai | anthropic
AI_BACKEND=ollama

# ── Ollama (default — free, runs on your machine) ────────────
OLLAMA_URL=http://localhost:11434

# Model to use with Ollama — run `ollama list` to see installed models
# Popular options: mistral, llama3, codellama, phi3, gemma
DEFAULT_MODEL=mistral:latest

# ── OpenAI (cloud, requires API key) ─────────────────────────
# Get your key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Anthropic (cloud, requires API key) ──────────────────────
# Get your key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── General settings ─────────────────────────────────────────
# How often (in seconds) the file watcher checks for changes
WATCH_INTERVAL=2

# Max file size to read (in KB) — files larger than this are skipped
MAX_FILE_KB=200
